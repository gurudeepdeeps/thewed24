rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read for all portfolio content
    match /films/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /about_profile/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /about_values/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /packages/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /albums/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /album_images/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Special case for enquiries - anyone can submit, but only admin can read
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
