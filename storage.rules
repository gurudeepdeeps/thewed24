rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 1. Allow public read for all assets
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Allow admin writes (save/edit/delete) for all assets
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}

