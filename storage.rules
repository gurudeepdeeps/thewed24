rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read for portfolio assets
    // Admin only for writes
    match /album_covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /albums/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /profile/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for anything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
